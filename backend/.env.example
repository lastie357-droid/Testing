# Server Configuration
PORT=5000
NODE_ENV=development

# TCP Port — Android devices connect here (matches Constants.TCP_PORT)
TCP_PORT=6000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/access-control

# Redis/Valkey Configuration (Aiven)
REDIS_URL=rediss://default:YOUR_PASSWORD@valkey-xxxxx.xx.aivencloud.com:22802

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_in_production

# Encryption Key (32 bytes hex)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# Admin Credentials (Default)
ADMIN_EMAIL=admin@remoteaccess.local
ADMIN_PASSWORD=admin123

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Socket.io Configuration
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# APK Builder Configuration
APK_OUTPUT_DIR=./apk-output
APK_TEMPLATE_DIR=./apk-template

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
